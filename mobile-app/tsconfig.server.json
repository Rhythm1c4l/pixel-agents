{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": ["ES2022"],
		"sourceMap": true,
		"rootDir": "..",
		"strict": true,
		"outDir": "dist",
		"noEmit": true
	},
	"include": [
		"server",
		"shared",
		"../shared/assets"
	],
	"exclude": [
		"node_modules",
		"dist",
		"server/test",
		"shared/test"
	]
}
